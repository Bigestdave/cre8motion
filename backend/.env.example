# Local development defaults. Do not commit real cloud credentials.
DATABASE_URL=sqlite:///./cre8motion.db
REDIS_URL=redis://localhost:6379/0
QWEN_API_KEY=
QWEN_BASE_URL=https://dashscope-intl.aliyuncs.com/compatible-mode/v1
# Set true to use deterministic local planning and placeholder media without external model calls.
DEMO_MODE=true
FRONTEND_ORIGINS=http://localhost:5173,http://127.0.0.1:5173
# Public HTTPS base URL of the deployed API, required for Qwen image-to-video keyframe retrieval.
PUBLIC_API_BASE_URL=https://your-public-api.example.com
