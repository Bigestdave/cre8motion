{
  "$schema": "https://openapi.vercel.sh/vercel.json",
  "rewrites": [
    { "source": "/api/:path*", "destination": "https://cre8motion.onrender.com/api/:path*" },
    { "source": "/media/:path*", "destination": "https://cre8motion.onrender.com/media/:path*" },
    { "source": "/(.*)", "destination": "/index.html" }
  ]
}
